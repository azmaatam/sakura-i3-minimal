[bar/i3wmthemer_bar]
width = 100%
height = 38
radius = 0
fixed-center = true
dpi = 128
monitor = ${env:MONITOR:}

background = #0f172a
foreground = #cdd6f4

line-size = 3
line-color =

border-size = 0
border-color =

padding-left = 0
padding-right = 2

module-margin-left = 1
module-margin-right = 2

font-0 = "Source Code Pro Semibold:size=13;1"
font-1 = "Font Awesome 7 Free:style=Solid:size=13;1"
font-2 = "Font Awesome 7 Brands:style=Regular:size=13;1"
font-3 = "dejavusans:pixelsize=16"

modules-left = brightness alsa  date
modules-center = i3
modules-right = battery memory cpu temperature bluetooth powermenu eth

tray-position = right
tray-maxsize = 32
;tray-padding =

cursor-click = pointer
cursor-scroll = ns-resize

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
index-sort = true
wrapping-scroll = false

label-mode-padding = 2
label-mode-foreground = #1d1e26
label-mode-background = #0f172a

label-focused = %index%
label-focused-background = #7aa2f7
label-focused-foreground = #ffffff
label-focused-padding = 2

label-unfocused = %index%
label-unfocused-background = #1b2333
label-unfocused-foreground = #cdd6f4
label-unfocused-padding = 2

label-visible = %index%
label-visible-background = #1b2333
label-visible-foreground = #cdd6f4
label-visible-padding = 2

label-urgent = %index%
label-urgent-background = #ff6b9b
label-urgent-padding = 2

[module/wlan]
type = internal/network
; interface = wlp107s0
interface = ${env:NET_IFACE:wlan0}
interval = 3.0

format-connected = <label-connected>
format-connected-foreground = #1d1e26
format-connected-background = #7aa2f7
format-connected-padding = 2
label-connected = %essid%

format-disconnected =

ramp-signal-0 = 
ramp-signal-1 = 
ramp-signal-2 = 
ramp-signal-3 = 
ramp-signal-4 = 
ramp-signal-foreground = #1d1e26

[module/eth]
type = internal/network
interface = wlp107s0
interval = 3.0

format-connected-padding = 2
format-connected-foreground = #1d1e26
format-connected-background = #789073
format-connected-prefix = " "
format-connected-prefix-foreground = #1d1e26
label-connected = %local_ip%

format-disconnected =

[module/date]
type = internal/date
interval = 1

date = " %b-%d-%Y"
date-alt =

time = %H:%M:%S
time-alt = %H:%M


format-prefix = 
format-foreground = #0f172a
format-background = #7aa2f7
format-padding = 2

label = %date% %time%

[module/powermenu]
type = custom/menu

expand-right = true

format-spacing = 1

label-open = 
label-open-foreground = #7aa2f7
label-close =  cancel
label-close-foreground = #7aa2f7
label-separator = |
label-separator-foreground = #7aa2f7

menu-0-0 = reboot
menu-0-0-exec = menu-open-1
menu-0-1 = power off
menu-0-1-exec = menu-open-2
menu-0-2 = log off
menu-0-2-exec = menu-open-3

menu-1-0 = cancel
menu-1-0-exec = menu-open-0
menu-1-1 = reboot
menu-1-1-exec = reboot

menu-2-0 = power off
menu-2-0-exec = poweroff
menu-2-1 = cancel
menu-2-1-exec = menu-open-0

menu-3-0 = log off
menu-3-0-exec = pkill -KILL -u $USER
menu-3-1 = cancel
menu-3-1-exec = menu-open-0

[module/battery]
type = internal/battery

battery = BAT0
adapter = ADP0

full-at = 98
low-at = 20
poll-interval = 30

format-charging = %{T1} %{T-}<label-charging>
format-discharging = <ramp-capacity> <label-discharging>
format-full = %{T1} %{T-} <label-full>
format-low = %{T1} %{T-} <label-low>

label-charging = %percentage%%
label-discharging = %percentage%%
label-full = %percentage%%
label-low = %percentage%%

ramp-capacity-0 = %{T1}%{T-}
ramp-capacity-1 = %{T1}%{T-}
ramp-capacity-2 = %{T1}%{T-}
ramp-capacity-3 = %{T1}%{T-}
ramp-capacity-4 = %{T1}%{T-}


[module/alsa]
type = internal/pulseaudio
interval = 1
format-volume = %{T1}<ramp-volume>%{T-} <label-volume>
label-muted = %{T1}%{T-}
label-muted-foreground = #66
label-volume = %percentage%%
ramp-volume-0 = 
ramp-volume-1 = 
ramp-volume-2 = 

[module/cpu]
type = internal/cpu
format = %{T1} %{T-} <label>
label = %percentage%%

[module/memory]
type = internal/memory
format = <label> <bar-used>
label = RAM %gb_used%

; Only applies if <bar-used> is used
bar-used-indicator =
bar-used-width = 5
bar-used-foreground-0 = #55aa55
bar-used-foreground-1 = #557755
bar-used-foreground-2 = #f5a70a
bar-used-foreground-3 = #ff5555
bar-used-fill = ▐
bar-used-empty = ▐
bar-used-empty-foreground = #444444

[module/temperature]
type = internal/temperature
; thermal-zone = 0
hwmon-path = /sys/class/hwmon/hwmon4/temp1_input
interval = 1
format = <label>
label =  %temperature-c%

[settings]
screenchange-reload = true

[global/wm]
margin-top = 0
margin-bottom = 0

[module/bluetooth]
type = custom/script
exec = ~/.config/polybar/scripts/bluetooth.sh
interval = 0
click-left = blueman-manager

[module/brightness]
type = custom/script
exec = bash -c 'P=$(brightnessctl g); M=$(brightnessctl m); printf " %d%%\n" $((P*100/M))'
interval = 0

click-left = brightnessctl set +1%
click-right = brightnessctl set 1%-
scroll-up = brightnessctl set +1%
scroll-down = brightnessctl set 1%-
